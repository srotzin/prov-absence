{
  "name": "@hivecivilization/prov-absence",
  "version": "0.0.1",
  "description": "Sorted-Merkle non-membership proofs — cryptographic attestations that an event did NOT occur.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "prov-absence": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "example": "tsx examples/audit-window.ts",
    "lint": "eslint src tests examples"
  },
  "keywords": [
    "merkle",
    "non-membership",
    "absence-proof",
    "cryptography",
    "audit",
    "provenance",
    "attestation"
  ],
  "author": "Hive Civilization",
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "SPEC.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
